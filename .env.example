# Скопируй этот файл в .env.local для локальной разработки
# В Vercel добавь эти переменные в Settings → Environment Variables

# ЮКасса (yookassa.ru → Настройки → Ключи API)
YOOKASSA_SHOP_ID=твой_shopId
YOOKASSA_SECRET_KEY=твой_секретный_ключ

# Supabase (для авторизации и заказов)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
